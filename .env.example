# ══════════════════════════════════════
# 統包先生 MR.TURNKEY — 環境變數
# 複製此檔案為 .env 並填入實際值
# ══════════════════════════════════════

# ── 應用程式 ──
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://localhost:3000/api

# ── 資料庫 ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tongbao
DB_USER=tongbao_user
DB_PASSWORD=your_db_password_here
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ── Redis（快取/Session）──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT 認證 ──
JWT_SECRET=your_jwt_secret_at_least_32_chars_long
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── AWS S3（檔案儲存）──
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET=tongbao-files
S3_CDN_BASE=https://cdn.tongbao.com

# ── Claude AI ──
ANTHROPIC_API_KEY=your_anthropic_api_key
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── LINE ──
LINE_CHANNEL_ID=your_channel_id
LINE_CHANNEL_SECRET=your_channel_secret
LINE_ACCESS_TOKEN=your_access_token
LINE_NOTIFY_TOKEN_ALL=your_notify_token

# ── 電子發票 ──
EINVOICE_API_URL=https://www-vc.tradevan.com.tw/DEFAULTAPI
EINVOICE_TAX_ID=90123456
EINVOICE_CERT_PATH=./certs/einvoice.pfx
EINVOICE_CERT_PASSWORD=your_cert_password

# ── ERP ──
ERP_PROVIDER=tiptop
ERP_API_URL=https://erp.tongbao.com/api/v1
ERP_API_KEY=your_erp_api_key
